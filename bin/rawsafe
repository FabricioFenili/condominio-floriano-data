#!/usr/bin/env bash
set -euo pipefail

ROOT="/workspaces/condominio-floriano-data"
LOG_DIR="${ROOT}/logs"
mkdir -p "${LOG_DIR}"
cd "${ROOT}"
export PYTHONPATH=src

STAMP="$(date +%Y%m%dT%H%M%S)"
LOG_FILE="${LOG_DIR}/rawsafe_${STAMP}.log"
FAILED=0

run_step() {
  local label="$1"
  shift

  {
    echo
    echo "============================================================"
    echo "STEP: ${label}"
    echo "CMD : $*"
    echo "TIME: $(date -Is)"
    echo "============================================================"
  } | tee -a "${LOG_FILE}"

  set +e
  "$@" 2>&1 | tee -a "${LOG_FILE}"
  local rc="${PIPESTATUS[0]}"
  set -e

  if [ "${rc}" -eq 0 ]; then
    echo "OK: ${label}" | tee -a "${LOG_FILE}"
  else
    echo "FALHA_CONTROLADA: ${label}" | tee -a "${LOG_FILE}"
    echo "EXIT_CODE=${rc}" | tee -a "${LOG_FILE}"
    FAILED=1
  fi
}

echo "RAWSAFE iniciado" | tee -a "${LOG_FILE}"
echo "ROOT=${ROOT}" | tee -a "${LOG_FILE}"
echo "PYTHONPATH=${PYTHONPATH}" | tee -a "${LOG_FILE}"

run_step "branch atual" git branch --show-current
run_step "status inicial" git status --short
run_step "testes existentes" pytest -q

echo | tee -a "${LOG_FILE}"
echo "============================================================" | tee -a "${LOG_FILE}"
echo "STEP: commit se houver alteração" | tee -a "${LOG_FILE}"
echo "============================================================" | tee -a "${LOG_FILE}"

git add -A 2>&1 | tee -a "${LOG_FILE}" || FAILED=1

if git diff --cached --quiet; then
  echo "OK: nenhuma alteração pendente para commit" | tee -a "${LOG_FILE}"
else
  set +e
  git commit -m "chore: checkpoint raw financial rollout" 2>&1 | tee -a "${LOG_FILE}"
  rc="${PIPESTATUS[0]}"
  set -e

  if [ "${rc}" -eq 0 ]; then
    echo "OK: commit criado" | tee -a "${LOG_FILE}"
  else
    echo "FALHA_CONTROLADA: commit falhou" | tee -a "${LOG_FILE}"
    echo "EXIT_CODE=${rc}" | tee -a "${LOG_FILE}"
    FAILED=1
  fi
fi

CURRENT_BRANCH="$(git branch --show-current || true)"

if [ -n "${CURRENT_BRANCH}" ]; then
  run_step "push origin/${CURRENT_BRANCH}" git push origin "${CURRENT_BRANCH}"
else
  echo "FALHA_CONTROLADA: branch atual não identificada" | tee -a "${LOG_FILE}"
  FAILED=1
fi

run_step "status final" git status --short
run_step "último commit" git log -1 --oneline

echo | tee -a "${LOG_FILE}"
if [ "${FAILED}" -eq 0 ]; then
  echo "STATUS_FINAL=OK" | tee -a "${LOG_FILE}"
else
  echo "STATUS_FINAL=FALHA_CONTROLADA" | tee -a "${LOG_FILE}"
  echo "LOG_FILE=${LOG_FILE}" | tee -a "${LOG_FILE}"
fi

echo
echo "Terminal preservado. Log: ${LOG_FILE}"

exit 0
