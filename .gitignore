cat >> .gitignore <<'EOF'

# Floriano data/privacy
.env
.env.*
!.env.example

data/**
!data/**/.gitkeep

db/*.duckdb
db/*.duckdb.wal
db/*.duckdb.tmp

*.zip
*.7z
*.tar
*.tar.gz

credentials*.json
service-account*.json
token*.json
secrets*.yml
secrets*.yaml

_pycache_/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
EOF
# FLORIANO_DATA_PRIVACY_BLOCK
# Dados reais do condomínio: nunca versionar
data/**
!data/
!data/**/
!data/**/.gitkeep

# DuckDB local
db/*.duckdb
db/*.duckdb.wal
db/*.duckdb.tmp

# Exportações
*.zip
*.7z
*.tar
*.tar.gz

# Credenciais e tokens
.env
.env.*
!.env.example
credentials*.json
service-account*.json
token*.json
secrets*.yml
secrets*.yaml

# Python/cache
_pycache_/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
